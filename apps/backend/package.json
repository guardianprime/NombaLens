{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend for the NombaLens project",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "watch": "tsc -w",
    "test": "jest --config jest.config.js",
    "check:env": "tsx src/scripts/checkEnv.ts",
    "check:db": "tsx src/scripts/checkDb.ts",
    "check:redis": "tsx src/scripts/checkRedis.ts",
    "check:nomba": "tsx src/scripts/checkNomba.ts",
    "db:migrate": "drizzle-kit migrate",
    "test:webhook": "tsx src/scripts/testWebhook.ts",
    "test:recovery": "tsx src/scripts/testRecovery.ts"
  },
  "keywords": [],
  "author": "Gordian Okon",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@nombalens/shared": "workspace:*",
    "bullmq": "^5.79.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "1.0.0-rc.4",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "postgres": "^3.4.9",
    "resend": "^6.16.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.43",
    "drizzle-kit": "1.0.0-rc.4",
    "tsx": "^4.22.5",
    "typescript": "^5.9.3"
  }
}
